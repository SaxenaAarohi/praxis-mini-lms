NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Prisma reads DATABASE_URL by convention.
# The MongoDB URI MUST include a database name (e.g. /mini_lms) for the Prisma MongoDB connector.
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mini_lms?retryWrites=true&w=majority

JWT_SECRET=change_me_to_a_strong_secret_min_32_chars
JWT_EXPIRES_IN=7d

# OpenRouter AI (https://openrouter.ai/keys)
# Optional: leave blank to use deterministic stub responses in development.
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Mini LMS

LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
